# SabPaisa Automation — Environment Variables (sample)
#
# Copy this file to `.env` and adjust values.
# .env is gitignored — never commit real credentials.
#
# To use:
#   bash:        export $(cat .env | xargs) && pytest tests/...
#   PowerShell:  Get-Content .env | ForEach-Object { if ($_ -match '^([^=]+)=(.*)$') { Set-Item "env:$($Matches[1])" $Matches[2] } }; pytest tests/...
#   Docker:      docker run --env-file .env --rm sabpaisa-tests

# ── Environment selection ─────────────────────────
ENV=Staging
# ENV=Production

# ── Browser behaviour ─────────────────────────────
HEADLESS=false
SLOW_MO=500
# In Docker / CI: HEADLESS=true, SLOW_MO=0

# ── Per-test merchant override ────────────────────
# Used by run_parallel_clients.py and dynamic tests
# MERCHANT_ID_OVERRIDE=CHIN36
# MERCHANT_ID_OVERRIDE=SUBI79

# Override for dynamic per-bank/per-wallet tests only
# DYNAMIC_CLIENT=SUBI79

# ── Playwright timeout (ms) ───────────────────────
TIMEOUT=15000

# ── Optional: alternate base URL ──────────────────
# BASE_URL=https://staging-sb-checkout.sabpaisa.in/checkout

# ── Notification / integration (optional) ────────
# SLACK_WEBHOOK_URL=
# JIRA_PROJECT_KEY=
# EMAIL_REPORT_TO=
